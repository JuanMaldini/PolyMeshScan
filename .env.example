# PolyMeshScan - variables de entorno (copiar a .env, no versionar .env real)
# Minimo posible a proposito - ver docs/INFRA.md.

# Dominio propio apuntando a tu VPS (usado por Caddy para HTTPS/Let's Encrypt).
DOMAIN=

# Ruta local donde pipeline/ lee/escribe escaneos exportados desde el iPhone.
SCANS_DIR=./scans

# URL de tu instancia de PocketBase (reusada de HYWorldWeb) usada como identity provider
# para el forward_auth de Caddy delante del viewer (ver docs/POCKETBASE.md y docs/INFRA.md).
POCKETBASE_URL=

# Nombre de tu tailnet de Tailscale (iPhone + esta PC ya deberian estar sumados ahi).
TAILSCALE_TAILNET=
